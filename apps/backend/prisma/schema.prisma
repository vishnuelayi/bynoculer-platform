generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())

  campaigns   Campaign[]
}

model Campaign {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("draft")

  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())
}